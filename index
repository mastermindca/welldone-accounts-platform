<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WELLDONE Accounting Challenge</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        /* Iframe & Graphy Optimizations */
        body, html { margin: 0; padding: 0; background: #f1f5f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; height: 100%; overflow: hidden; }
        #app-container { height: 100vh; overflow-y: auto; overflow-x: hidden; scroll-behavior: smooth; }
        .brand-blue { color: #0033A0; } .bg-brand-blue { background-color: #0033A0; }
        .brand-green { color: #1E8B22; } .bg-brand-green { background-color: #1E8B22; }
        .brand-red { color: #D3121E; }
        .brand-gold { color: #F7C600; }
        .screen { display: none; min-height: 100%; padding-bottom: 80px; }
        .screen.active { display: block; animation: fadeIn 0.4s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        /* Inputs & Buttons */
        .input-field { width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; margin-bottom: 16px; font-size: 16px; outline: none; transition: border-color 0.2s; }
        .input-field:focus { border-color: #0033A0; box-shadow: 0 0 0 3px rgba(0,51,160,0.1); }
        .btn-primary { background: #0033A0; color: white; padding: 14px 24px; border-radius: 8px; font-weight: 600; width: 100%; text-align: center; cursor: pointer; transition: 0.2s; display: block; }
        .btn-primary:hover { background: #002277; }
        .btn-whatsapp { background: #25D366; color: white; padding: 14px 24px; border-radius: 8px; font-weight: 600; width: 100%; text-align: center; cursor: pointer; display: block; }
        .float-wa { position: fixed; bottom: 20px; right: 20px; background: #25D366; color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); z-index: 100; cursor: pointer; }
    </style>
</head>
<body>

<div id="app-container">
    <header class="bg-white shadow-sm p-4 sticky top-0 z-50">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <div>
                <h1 class="font-bold text-xl brand-blue leading-tight">WELLDONE<br><span class="text-sm font-normal text-gray-500">COMMERCE CLASSES</span></h1>
            </div>
            <div class="text-right">
                <p class="text-xs text-gray-500">Mentored by</p>
                <h2 class="font-bold text-gray-800">CA Anand Kabra</h2>
            </div>
        </div>
    </header>

    <div id="screen-landing" class="screen active max-w-4xl mx-auto p-4 mt-6">
        <div class="bg-white rounded-2xl shadow-lg p-6 text-center border-t-4 border-[#0033A0]">
            <span class="bg-blue-100 text-blue-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Free Interactive Test</span>
            <h2 class="text-3xl font-extrabold mt-4 mb-2 text-gray-800">Can you pass the <span class="brand-red">Journal Entry</span> → <span class="brand-blue">Ledger</span> → <span class="brand-green">Balance Sheet</span> test?</h2>
            <p class="text-gray-600 mb-6 font-medium">Solve free journal questions and see live effect on Ledger, Trial Balance and Balance Sheet like Tally.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8 text-left">
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                    <i class="fas fa-bolt brand-gold text-2xl mb-2"></i>
                    <h3 class="font-bold text-gray-800">3 Free Questions</h3>
                    <p class="text-sm text-gray-500">Test your foundation immediately.</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                    <i class="fas fa-chart-pie text-blue-500 text-2xl mb-2"></i>
                    <h3 class="font-bold text-gray-800">Live Ledger Impact</h3>
                    <p class="text-sm text-gray-500">See real-time Tally-like effects.</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                    <i class="fas fa-certificate brand-green text-2xl mb-2"></i>
                    <h3 class="font-bold text-gray-800">Instant Scorecard</h3>
                    <p class="text-sm text-gray-500">Get your rank & accuracy report.</p>
                </div>
            </div>
            <button onclick="nav('screen-login')" class="btn-primary text-lg py-4">Start Free Challenge <i class="fas fa-arrow-right ml-2"></i></button>
            <p class="mt-4 text-sm text-gray-400">Concepts → Confidence → Results | Soppa Hai Learning System</p>
        </div>
    </div>

    <div id="screen-login" class="screen max-w-md mx-auto p-4 mt-6">
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <h2 class="text-2xl font-bold mb-1">Join the Challenge</h2>
            <p class="text-gray-500 text-sm mb-6">Enter details to generate your scorecard</p>
            
            <input type="text" id="lf-name" class="input-field" placeholder="Full Name" required>
            <input type="tel" id="lf-phone" class="input-field" placeholder="WhatsApp Number" required>
            <select id="lf-course" class="input-field" required>
                <option value="" disabled selected>Select Course / Class</option>
                <option>11th Accounts</option>
                <option>12th Accounts</option>
                <option>CA Foundation Accounts</option>
                <option>Other</option>
            </select>
            <input type="text" id="lf-city" class="input-field" placeholder="City" required>
            
            <button onclick="submitLogin()" class="btn-primary">Generate My Free Scorecard</button>
        </div>
    </div>

    <div id="screen-dash" class="screen max-w-4xl mx-auto p-4 mt-6">
        <h2 class="text-2xl font-bold mb-4">Welcome, <span id="dash-name" class="brand-blue"></span>!</h2>
        <p class="mb-6 text-gray-600">Choose your next step below:</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-blue-500 cursor-pointer hover:shadow-md transition" onclick="startChallenge()">
                <div class="flex justify-between items-center mb-2">
                    <h3 class="font-bold text-lg">Start 3-Minute Challenge</h3>
                    <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">FREE</span>
                </div>
                <p class="text-sm text-gray-500">Attempt 3 free journal entries & see live effects.</p>
            </div>
            
            <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-green-500 cursor-pointer hover:shadow-md transition" onclick="alert('Complete 3 free questions first to unlock!')">
                <div class="flex justify-between items-center mb-2">
                    <h3 class="font-bold text-lg">Bonus Unlock</h3>
                    <i class="fas fa-lock text-gray-400"></i>
                </div>
                <p class="text-sm text-gray-500">Share on WhatsApp to unlock 2 bonus questions.</p>
            </div>

            <div class="bg-gray-100 p-5 rounded-xl border border-gray-200 opacity-70">
                <div class="flex justify-between items-center mb-2">
                    <h3 class="font-bold text-lg">CA Foundation Accounts</h3>
                    <span class="bg-gray-200 text-gray-600 text-xs px-2 py-1 rounded">Coming Soon</span>
                </div>
            </div>
        </div>
    </div>

    <div id="screen-challenge" class="screen max-w-2xl mx-auto p-4 mt-4">
        <div class="bg-white p-4 rounded-xl shadow-sm mb-4 flex justify-between items-center">
            <div class="font-bold text-gray-700">Question <span id="q-curr">1</span> / <span id="q-tot">3</span></div>
            <div class="text-brand-red font-mono font-bold"><i class="fas fa-clock"></i> <span id="timer">00:00</span></div>
        </div>
        
        <div class="w-full bg-gray-200 rounded-full h-2 mb-6"><div class="bg-blue-600 h-2 rounded-full" id="progress-bar" style="width: 33%"></div></div>

        <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100">
            <h3 class="text-lg font-bold mb-4" id="q-text">Started business with Cash ₹100,000</h3>
            
            <div class="space-y-4">
                <div class="flex gap-2 items-center">
                    <div class="w-16 font-bold text-gray-600">Dr.</div>
                    <select id="ans-dr" class="input-field mb-0 flex-1"><option value="">Select Account...</option><option value="Cash">Cash A/c</option><option value="Capital">Capital A/c</option></select>
                </div>
                <div class="flex gap-2 items-center">
                    <div class="w-16 font-bold text-gray-600">Cr.</div>
                    <select id="ans-cr" class="input-field mb-0 flex-1"><option value="">Select Account...</option><option value="Cash">Cash A/c</option><option value="Capital">Capital A/c</option></select>
                </div>
                <button onclick="checkAnswer()" class="btn-primary mt-4">Submit Entry</button>
            </div>
        </div>

        <div id="impact-panel" class="mt-6 bg-blue-50 p-5 rounded-xl border border-blue-100 hidden">
            <h3 class="font-bold text-blue-900 mb-2"><i class="fas fa-bolt text-yellow-500"></i> Live Ledger Impact</h3>
            <div id="impact-text" class="text-sm text-gray-700 space-y-2"></div>
        </div>
    </div>

    <div id="screen-score" class="screen max-w-md mx-auto p-4 mt-6">
        <div class="bg-white rounded-2xl shadow-lg p-6 text-center">
            <i class="fas fa-trophy text-5xl text-yellow-400 mb-4"></i>
            <h2 class="text-2xl font-bold mb-2">Challenge Completed!</h2>
            <p class="text-gray-500 mb-6">Your Initial Report</p>
            
            <div class="flex justify-around mb-6 bg-gray-50 p-4 rounded-xl">
                <div><p class="text-xs text-gray-500 uppercase">Score</p><p class="text-2xl font-bold brand-blue" id="final-score">2/3</p></div>
                <div><p class="text-xs text-gray-500 uppercase">Accuracy</p><p class="text-2xl font-bold brand-green" id="final-acc">66%</p></div>
            </div>

            <button onclick="shareAndUnlock()" class="btn-whatsapp mb-3"><i class="fab fa-whatsapp mr-2"></i> Share to Unlock 2 Bonus Qs</button>
            <button onclick="nav('screen-gate')" class="w-full py-3 text-gray-600 font-bold border border-gray-300 rounded-lg">Get Detailed PDF Report</button>
        </div>
    </div>

</div>

<a href="https://wa.me/919923848041" target="_blank" class="float-wa"><i class="fab fa-whatsapp"></i></a>

<script>
    // Config
    const CONFIG = {
        webhookUrl: 'YOUR_APPS_SCRIPT_WEB_APP_EXEC_URL',
        questions: [
            { q: "Started business with Cash ₹100,000", dr: "Cash", cr: "Capital", amt: 100000, drType: "Asset Increase", crType: "Capital Increase" },
            { q: "Bought goods for Cash ₹20,000", dr: "Purchases", cr: "Cash", amt: 20000, drType: "Expense", crType: "Asset Decrease" },
            { q: "Sold goods on credit to John ₹15,000", dr: "John", cr: "Sales", amt: 15000, drType: "Debtor Increase", crType: "Income Increase" },
            { q: "Paid rent ₹5,000", dr: "Rent", cr: "Cash", amt: 5000, drType: "Expense", crType: "Asset Decrease" },
            { q: "Depreciation charged on Machinery ₹2,000", dr: "Depreciation", cr: "Machinery", amt: 2000, drType: "Expense", crType: "Asset Decrease" }
        ]
    };

    let state = { user: {}, qIndex: 0, score: 0, totalQs: 3, timer: 0, interval: null, sessionId: Date.now() };

    function nav(screenId) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(screenId).classList.add('active');
        document.getElementById('app-container').scrollTop = 0;
    }

    function sendEvent(eventName, extra = {}) {
        if(CONFIG.webhookUrl === 'YOUR_APPS_SCRIPT_WEB_APP_EXEC_URL') return;
        fetch(CONFIG.webhookUrl, {
            method: 'POST', mode: 'no-cors',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify({ type: 'event', event: eventName, sessionId: state.sessionId, platform: 'Accounts Challenge', ...state.user, ...extra })
        }).catch(e => console.log('Event tracked locally'));
    }

    function submitLogin() {
        const name = document.getElementById('lf-name').value;
        const phone = document.getElementById('lf-phone').value;
        const course = document.getElementById('lf-course').value;
        if(!name || !phone || !course) return alert('Please fill all fields');
        
        state.user = { name, whatsapp: phone, course, city: document.getElementById('lf-city').value };
        localStorage.setItem('wdUser', JSON.stringify(state.user));
        
        sendEvent('lead_started', { type: 'lead' });
        document.getElementById('dash-name').innerText = name;
        nav('screen-dash');
        sendEvent('after_login_screen_viewed');
    }

    function startChallenge() {
        state.qIndex = 0; state.score = 0;
        state.interval = setInterval(() => { state.timer++; document.getElementById('timer').innerText = new Date(state.timer * 1000).toISOString().substr(14, 5); }, 1000);
        nav('screen-challenge');
        sendEvent('challenge_started');
        loadQuestion();
    }

    function loadQuestion() {
        const qData = CONFIG.questions[state.qIndex];
        document.getElementById('q-text').innerText = qData.q;
        document.getElementById('q-curr').innerText = state.qIndex + 1;
        document.getElementById('q-tot').innerText = state.totalQs;
        document.getElementById('progress-bar').style.width = ((state.qIndex) / state.totalQs * 100) + '%';
        
        // Populate dropdowns (simplified for demo)
        const opts = `<option value="">Select...</option><option value="Cash">Cash A/c</option><option value="Capital">Capital A/c</option><option value="Purchases">Purchases A/c</option><option value="Sales">Sales A/c</option><option value="John">John A/c</option><option value="Rent">Rent A/c</option><option value="Machinery">Machinery A/c</option><option value="Depreciation">Depreciation A/c</option>`;
        document.getElementById('ans-dr').innerHTML = opts;
        document.getElementById('ans-cr').innerHTML = opts;
        document.getElementById('impact-panel').classList.add('hidden');
    }

    function checkAnswer() {
        const qData = CONFIG.questions[state.qIndex];
        const dr = document.getElementById('ans-dr').value;
        const cr = document.getElementById('ans-cr').value;
        
        if(!dr || !cr) return alert('Select both Debit and Credit accounts');
        
        const isCorrect = (dr === qData.dr && cr === qData.cr);
        if(isCorrect) {
            state.score++;
            confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
        }
        
        sendEvent('question_attempted', { qIndex: state.qIndex, correct: isCorrect });

        // Show Impact
        const panel = document.getElementById('impact-panel');
        document.getElementById('impact-text').innerHTML = `
            <div><strong>Dr. ${dr}</strong>: ${isCorrect ? qData.drType : 'Incorrect Impact'} (₹${qData.amt})</div>
            <div><strong>Cr. ${cr}</strong>: ${isCorrect ? qData.crType : 'Incorrect Impact'} (₹${qData.amt})</div>
        `;
        panel.classList.remove('hidden');

        setTimeout(() => {
            state.qIndex++;
            if(state.qIndex >= state.totalQs) endChallenge();
            else loadQuestion();
        }, 3000);
    }

    function endChallenge() {
        clearInterval(state.interval);
        document.getElementById('final-score').innerText = `${state.score}/${state.totalQs}`;
        document.getElementById('final-acc').innerText = Math.round((state.score/state.totalQs)*100) + '%';
        nav('screen-score');
        sendEvent('challenge_completed', { score: state.score, total: state.totalQs });
    }

    function shareAndUnlock() {
        sendEvent('shared_unlock_clicked');
        const text = encodeURIComponent(`Can you pass the WELLDONE Accounting Challenge? I scored ${state.score}/${state.totalQs}! Try it here: [APP_LINK]`);
        window.open(`https://wa.me/?text=${text}`, '_blank');
        
        setTimeout(() => {
            state.totalQs = 5; // Unlock 2 more
            alert('2 Bonus Questions Unlocked!');
            nav('screen-challenge');
            loadQuestion();
        }, 2000);
    }
</script>
</body>
</html>
